# 构建时注入的公开 Supabase 配置
# 复制此文件为 .env 或 .env.local 后再运行 npm run build / ./deploy.sh
# 不要把 service_role key、Resend key 等私密配置写进前端环境变量

VITE_SUPABASE_URL=https://your-project-url.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 可选：只在前端弹窗里展示脱敏后的管理员收件邮箱提示
# 真实收件邮箱请配置到 Supabase Function Secret: ADMIN_NOTIFICATION_EMAIL
VITE_ADMIN_NOTIFICATION_EMAIL_HINT=a***@icloud.com
